# UrbanFlow Configuration
# ========================
# Copy this to .env and fill in your values.
# Never commit the real .env file to version control.

# ── Server ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_VERSION=v1
API_TIMEOUT=10000
CORS_ORIGIN=http://localhost:8081

# ── Active City ─────────────────────────────────────────────────────
ACTIVE_CITY=delhi
# Options: delhi, bangalore, chennai

# ── JWT ─────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_random_64_char_hex_string
JWT_EXPIRY=7d

# ── Rate Limiting ───────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── Logging ─────────────────────────────────────────────────────────
LOG_LEVEL=debug

# ── Delhi GTFS-RT (DIMTS / OTD) ────────────────────────────────────
# Register at https://otd.delhi.gov.in
DELHI_API_URL=https://otd.delhi.gov.in/api/realtime
DELHI_API_KEY=

# ── Bengaluru GTFS-RT (DULT) ────────────────────────────────────────
# Register at https://dult.in (if available)
DULT_VEHICLE_POSITIONS_URL=
DULT_TRIP_UPDATES_URL=
DULT_ALERTS_URL=
DULT_API_KEY=

# ── Chennai GTFS-RT ─────────────────────────────────────────────────
CHENNAI_API_URL=
CHENNAI_API_KEY=

# ── Traffic (TomTom) ────────────────────────────────────────────────
# Register free at https://developer.tomtom.com
TOMTOM_API_KEY=

# ── AQI (CPCB via data.gov.in) ──────────────────────────────────────
# Register free at https://data.gov.in
CPCB_API_KEY=

# ── OpenTripPlanner ─────────────────────────────────────────────────
OTP_API_URL=http://localhost:8080/otp/routers/default

# ── SSL / HTTPS (production only) ───────────────────────────────────
# SSL_CERT_PATH=./certs/cert.pem
# SSL_KEY_PATH=./certs/key.pem
