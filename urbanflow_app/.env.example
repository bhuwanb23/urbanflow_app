# UrbanFlow Mobile App Configuration
# ====================================
# Copy this to .env and fill in your values.
# Never commit the real .env file to version control.
#
# These values are available at build time only (not hot-reload).
# After changing .env, run: npx expo start --clear

# Backend API URL (default: http://localhost:3000)
# For Android emulator use: http://10.0.2.2:3000
# For physical device use your machine's LAN IP
EXPO_PUBLIC_API_URL=http://localhost:3000

# Google Maps API key (optional).
# When set, the in-app MapView uses the Google Maps provider on iOS/Android.
# Leave empty to use the default OpenStreetMap (no-key) provider — maps still work.
GOOGLE_MAPS_API_KEY=

# Sentry DSN (optional). When set, crash/error reporting is enabled.
# Leave empty to disable Sentry (no-op).
SENTRY_DSN=

# Sentry environment label (optional). Used in Sentry events.
SENTRY_ENV=production

