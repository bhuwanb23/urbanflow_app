{
  "name": "urbanflow-backend",
  "version": "1.0.0",
  "description": "UrbanFlow Backend API - Multimodal Urban Transport System for Bengaluru",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "node scripts/coverage-runner.js",
    "lint": "eslint . --ext .js --max-warnings 0",
    "lint:fix": "eslint . --ext .js --fix",
    "seed": "node scripts/seed-data.js",
    "preprocess": "node scripts/run-preprocess.js",
    "setup:chennai": "node scripts/setup-chennai.js",
    "otp:download": "cd otp && pwsh -ExecutionPolicy Bypass -File download-data.ps1",
    "otp:start": "cd otp && pwsh -ExecutionPolicy Bypass -File start-otp.ps1",
    "otp:stop": "cd otp && pwsh -ExecutionPolicy Bypass -File stop-otp.ps1"
  },
  "keywords": [
    "urbanflow",
    "transport",
    "bengaluru",
    "gtfs",
    "multimodal",
    "api"
  ],
  "author": "UrbanFlow Team",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "fuse.js": "^7.0.0",
    "gtfs-realtime-bindings": "^1.1.1",
    "helmet": "^7.1.0",
    "joi": "^18.2.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.11.0",
    "protobufjs": "^7.5.4",
    "sequelize": "^6.37.8",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sqlite3": "^6.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  }
}
